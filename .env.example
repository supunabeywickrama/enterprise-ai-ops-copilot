# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# Bedrock Model IDs
BEDROCK_CHAT_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
BEDROCK_GUARDRAIL_ID=your-guardrail-id
BEDROCK_GUARDRAIL_VERSION=DRAFT

# Vector Store
VECTOR_STORE_TYPE=chroma           # chroma | opensearch
CHROMA_PERSIST_DIR=./chroma_db
OPENSEARCH_ENDPOINT=https://your-opensearch-endpoint
OPENSEARCH_INDEX=enterprise-ops

# App Settings
APP_ENV=development                # development | staging | production
LOG_LEVEL=INFO
API_PORT=8000

# ServiceNow (mock by default)
SERVICENOW_MOCK=true
SERVICENOW_BASE_URL=https://your-instance.service-now.com
SERVICENOW_USER=admin
SERVICENOW_PASSWORD=your-password

# Snowflake (mock by default)
SNOWFLAKE_MOCK=true
SNOWFLAKE_ACCOUNT=your-account
SNOWFLAKE_USER=your-user
SNOWFLAKE_PASSWORD=your-password
SNOWFLAKE_DATABASE=OPS_DB
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_WAREHOUSE=COMPUTE_WH

# Teams (mock by default)
TEAMS_MOCK=true
TEAMS_WEBHOOK_URL=https://your-teams-webhook-url
